# Copy to .env.local and fill in.

# --- AI Insights (freellmapi, OpenAI-compatible) ---
# Local dev points at the freellmapi Docker proxy. For production, point at a hosted
# OpenAI-compatible endpoint + key.
FREELLMAPI_BASE_URL=http://localhost:3001/v1
FREELLMAPI_KEY=your-freellmapi-key
FREELLMAPI_MODEL=auto

# --- Liquidity data (DefiLlama + CoinGecko) ---
# Keyless — nothing to set.

# --- Exchange: LI.FI swap (integrator "iceswap", no key) ---
# Optional WalletConnect Cloud projectId to enable mobile/QR wallets.
# Installed extension wallets (MetaMask, Rabby, Coinbase, Phantom…) work without it (EIP-6963).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Exchange: Onramper fiat on-ramp (the aggregator LI.FI uses) ---
# Publishable key (client-safe). pk_test_ = staging, pk_prod_ = live.
NEXT_PUBLIC_ONRAMPER_API_KEY=
