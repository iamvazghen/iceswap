# Copy to .env.local and fill in.

# --- AI Insights (Google Gemini, OpenAI-compatible endpoint) ---
# Get a key from Google AI Studio (https://aistudio.google.com/apikey).
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Liquidity data (DefiLlama + CoinGecko) ---
# Keyless — nothing to set.

# --- Exchange: LI.FI swap (integrator "iceswap", no key) ---
# Optional WalletConnect Cloud projectId to enable mobile/QR wallets.
# Installed extension wallets (MetaMask, Rabby, Coinbase, Phantom…) work without it (EIP-6963).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
